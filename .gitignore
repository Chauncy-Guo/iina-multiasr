# ============================================================
# IINA plugin build artifacts
# ============================================================
# dist/ is committed on main (IINA downloads the repo directly when
# installing via "Install from GitHub"). To regenerate, run bundle.sh
# and commit the updated dist/ folder.
# dist/
node_modules/
*.log
.DS_Store

# Local build outputs (iinaplgz packages)
*.iinaplgz

# ============================================================
# Generated subtitle caches (created at runtime)
# ============================================================
*.srt
*.vtt
*.wav
*.tmp

# ============================================================
# Secrets (NEVER commit API keys)
# ============================================================
.env
.env.*
secrets.json
*-credentials.json
.parcel-cache/
