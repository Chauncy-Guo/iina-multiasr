{
  "name": "iina-multiasr",
  "version": "0.1.0",
  "description": "IINA plugin: cloud ASR + LLM translation",
  "private": true,
  "scripts": {
    "build": "parcel build src/index.js src/global.js --dist-dir dist --no-cache",
    "build:html": "cp pref.html dist/pref.html",
    "clean": "rm -rf dist .parcel-cache",
    "prepare": "npm run clean && npm run build && npm run build:html",
    "pack": "iina-plugin pack ."
  },
  "targets": {
    "default": {
      "context": "browser",
      "outputFormat": "global",
      "isLibrary": false,
      "optimize": true,
      "engines": {
        "browsers": "last 1 Chrome version"
      }
    }
  },
  "devDependencies": {
    "parcel": "^2.12.0",
    "iina-plugin": "^0.1.0"
  }
}
